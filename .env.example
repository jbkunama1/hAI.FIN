# hAI.FIN – Environment Configuration
# ============================================
# Kopiere diese Datei zu .env und trage deine echten Werte ein.
# NIEMALS die .env-Datei in Git einchecken!

# ============================================
# LLM / 9Router
# ============================================
OPENAI_API_BASE=https://your-9router-host.example.com/v1
OPENAI_API_KEY=your-9router-api-key-here
MODEL_NAME=gpt-4o-mini

# ============================================
# eToro API (NUR Agent Portfolio!)
# Keys: eToro > Settings > Trading > API Key Management
# ============================================
ETORO_PUBLIC_KEY=REPLACE_WITH_YOUR_ETORO_PUBLIC_KEY
ETORO_USER_KEY=REPLACE_WITH_YOUR_ETORO_USER_KEY
ETORO_BASE_URL=https://public-api.etoro.com/api/v1
ETORO_AGENT_PORTFOLIO_ID=REPLACE_WITH_YOUR_PORTFOLIO_ID

# ============================================
# Marktdaten-APIs (kostenlose Tiers)
# ============================================

# Finnhub – Earnings-Kalender, News-Sentiment
# Kostenloser Key: https://finnhub.io/register
# Free Tier: 60 Calls/Minute
FINNHUB_KEY=REPLACE_WITH_YOUR_FINNHUB_KEY

# Alpha Vantage – RSI, MACD, Fundamentaldaten
# Kostenloser Key: https://www.alphavantage.co/support/#api-key
# Free Tier: 25 Calls/Tag
ALPHA_VANTAGE_KEY=REPLACE_WITH_YOUR_ALPHA_VANTAGE_KEY

# ============================================
# Telegram-Notifier
# ============================================
# 1. Bot erstellen: Telegram > @BotFather > /newbot
# 2. Token kopieren (sieht aus wie: 123456789:ABCdef...)
# 3. Bot in deinen Chat/Gruppe einladen
# 4. Chat-ID ermitteln:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates
#    -> Suche nach "chat":{"id": 12345678}
TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_YOUR_CHAT_ID
# Morgen-Briefing bei jedem Agent-Start senden (true/false)
TELEGRAM_MORNING_BRIEFING=true

# ============================================
# Trading Guardrails
# ============================================
MAX_TRADES_PER_DAY=3
MAX_POSITION_PERCENT=10
MIN_CASH_RESERVE_PCT=0.20
MAX_POSITION_PCT=0.10
ORDER_SIZE_PCT=0.05
VIX_EMERGENCY=40
ALLOWED_ASSETS=SPY,QQQ,VTI
INITIAL_CASH=10000

ENABLE_SHORT=false
ENABLE_LEVERAGE=false

# ============================================
# Agent-Verhalten
# ============================================
LOG_LEVEL=INFO
# WICHTIG: Erst testen mit true, dann auf false fuer echte Trades!
DRY_RUN=true
